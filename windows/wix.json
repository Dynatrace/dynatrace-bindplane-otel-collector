{
  "product": "Dynatrace Bindplane Distribution of OpenTelemetry Collector",
  "company": "TODO-DBDOT-VENDOR",
  "license": "./LICENSE.rtf",
  "info": {
    "help-link": "https://bindplane.com/contact/",
    "support-link": "https://bindplane.com/contact/"
  },
  "upgrade-code": "CDE0E02B-C29C-43AA-A6A3-063A84DC7EDF",
  "files": [
    {
      "path": "dbdot-collector.exe",
      "service": {
        "name": "dbdot-collector",
        "start": "delayed",
        "display-name": "Dynatrace Bindplane Distribution of OpenTelemetry Collector",
        "description": "Dynatrace Bindplane Distribution of OpenTelemetry Collector.",
        "arguments": "--config &quot;[INSTALLDIR]config.yaml&quot; --logging &quot;[INSTALLDIR]logging.yaml&quot; --manager &quot;[INSTALLDIR]manager.yaml&quot;"
      }
    },
    {
      "path": "updater.exe"
    },
    {
      "path": "config.yaml",
      "never_overwrite": true
    },
    {
      "path": "logging.yaml",
      "never_overwrite": true
    },
    {
      "path": "VERSION.txt"
    },
    {
      "path": "LICENSE"
    }
  ],
  "directories": [
    {
      "name": "plugins"
    },
    {
      "name": "storage"
    },
    {
      "name": "install"
    }
  ],
  "environments": [
    {
      "name": "BINDPLANE_COLLECTOR_STORAGE",
      "value": "[INSTALLDIR]storage",
      "permanent": "no",
      "system": "yes",
      "action": "set",
      "part": "all"
    },
    {
      "name": "BINDPLANE_COLLECTOR_HOME",
      "value": "[INSTALLDIR]",
      "permanent": "no",
      "system": "yes",
      "action": "set",
      "part": "all"
    },
    {
      "name": "DBDOT_USER_GROUP_SID",
      "value": "System.Security.Principal.SecurityIdentifier('S-1-5-32-545')",
      "permanent": "no",
      "system": "yes",
      "action": "set",
      "part": "all"
    },
    {
      "name": "DBDOT_USER_GROUP_NAME",
      "value": "[DBDOT_USER_GROUP_SID].Translate([System.Security.Principal.NTAccount]).Value",
      "permanent": "no",
      "system": "yes",
      "action": "set",
      "part": "all"
    }
  ],
  "registries": [
    {
      "path": "HKCU\\Software\\Dynatrace\\DBDOT",
      "values": [
        {
          "name": "Version",
          "value": "v[ProductVersion]"
        },
        {
          "name": "InstallDir",
          "value": "[INSTALLDIR]"
        }
      ]
    },
    {
      "path": "HKLM\\Software\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\Dynatrace Bindplane Distribution of OpenTelemetry Collector",
      "values": [
        {
          "name": "NoModify",
          "value": "1",
          "type": "integer"
        }
      ]
    }
  ],
  "hooks": []
}
