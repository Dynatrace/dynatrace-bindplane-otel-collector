[Unit]
Description=Dynatrace Bindplane Distribution of OpenTelemetry Collector
After=network.target
StartLimitIntervalSec=120
StartLimitBurst=5
[Service]
Type=simple
User=root
Group=dbdot
Environment=PATH=/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin
Environment=BINDPLANE_COLLECTOR_HOME=/opt/dbdot-collector
Environment=DBDOT_OTEL_COLLECTOR_STORAGE=/opt/dbdot-collector/storage
WorkingDirectory=/opt/dbdot-collector
ExecStart=/opt/dbdot-collector/dbdot-collector --config config.yaml
LimitNOFILE=65000
SuccessExitStatus=0
TimeoutSec=20
StandardOutput=journal
Restart=on-failure
RestartSec=5s
KillMode=process
[Install]
WantedBy=multi-user.target 
